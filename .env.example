# 开发：留空即可，请求走 Vite 代理 /api → http://localhost:3001
# 生产（Vercel）：在 Project → Settings → Environment Variables 添加：
#   VITE_API_BASE = https://你的项目.up.railway.app
# 保存后必须 Redeploy，Vite 会在构建时写入该值
VITE_API_BASE=

# 可选：仅改开发代理目标，默认 http://localhost:3001
# VITE_API_PROXY_TARGET=http://localhost:3001

# 飞书多维表格（后端 server/.env.example 有完整说明）
# FEISHU_APP_ID=
# FEISHU_APP_SECRET=
# FEISHU_APP_TOKEN=
# FEISHU_TABLE_ID=
