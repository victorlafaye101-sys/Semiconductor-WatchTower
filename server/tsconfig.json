{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "noEmit": true
  },
  "include": [
    "index.ts",
    "utils/**/*.ts",
    "data/**/*.ts",
    "services/**/*.ts"
  ]
}
